// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// DATABASE SCHEMA — HabitSwipe
// Using PostgreSQL via Supabase
// ─────────────────────────────────────────────────────────────────────────────

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── USER ────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?   @unique
  image         String?   // avatar URL
  password      String?   // null for OAuth users
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  phone         String?           // mobile number
  bio           String?           // short bio
  referralCode  String?  @unique  // this user's own referral code
  referredBy    String?           // referral code used when signing up


  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  habits   Habit[]
  logs     HabitLog[]
  snapLogs SnapShareLog[]

  @@map("users")
}

// ─── NEXTAUTH TABLES ─────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── HABIT ───────────────────────────────────────────────────────────────────
// A habit belongs to one user. Frequency controls which days it appears.
model Habit {
  id         String        @id @default(cuid())
  userId     String
  name       String
  icon       String        @default("⚡")  // emoji
  color      String        @default("#6366f1") // hex
  frequency  HabitFrequency @default(DAILY)
  targetDays Int           @default(7)   // days per week for WEEKLY habits
  isArchived Boolean       @default(false)
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@map("habits")
}

enum HabitFrequency {
  DAILY   // appears every day
  WEEKLY  // appears X days per week (user picks count)
}

// ─── HABIT LOG ────────────────────────────────────────────────────────────────
// One record per habit per day — created when user swipes
model HabitLog {
  id        String    @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime  @db.Date  // only the date, no time
  status    LogStatus
  createdAt DateTime  @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One log per habit per day
  @@unique([habitId, date])
  @@map("habit_logs")
}

enum LogStatus {
  DONE    // swiped right ✅
  SKIPPED // swiped left ❌
}


// ─── STREAK MILESTONE ────────────────────────────────────────────────────────
// Records when a user hits a streak milestone (7, 14, 30, 60, 100 days).
// Used to show achievements on the Streaks page.
model StreakMilestone {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  milestone Int      // 7, 14, 30, 60, 100
  achieved  Boolean  @default(false)
  achievedAt DateTime?
  createdAt DateTime @default(now())

  @@unique([habitId, milestone])
  @@map("streak_milestones")
}

// ─── SNAP SHARE LOG ──────────────────────────────────────────────────────────
// Records when a user shares a snap of their habit. Used for the calendar history.
model SnapShareLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date // Only the date, no time
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One log per user per day max
  @@unique([userId, date])
  @@map("snap_share_logs")
}